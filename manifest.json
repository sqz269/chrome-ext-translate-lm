{
  "manifest_version": 3,
  "name": "LM Translate",
  "version": "0.1.0",
  "description": "Translate selected text or images using a local LM Studio instance.",
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "host_permissions": [
    "http://localhost:1234/*",
    "http://127.0.0.1:1234/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LM Translate Settings"
  },
  "icons": {}
}
